<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <header>
  <h1>Westridge Fall and Spring Service Fairs</h1>
  <div class="topnav">
      <img class="topnav" src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ85LfapTlMyrVyiucF-V1ZXqloAU1ILb5bBw&s" alt="User Avatar">
      <form action="/search">
        <input type="text" placeholder="Search projects..." name="search" style="padding: 5px; border: 1px solid var(--westridge-green);">
        <button type="submit" style="background: var(--westridge-green); color: white; padding: 5px 10px; border: none; cursor: pointer;">Enter</button>
      </form>
  </div>
  </header>

  <p>Welcome to the Westridge Service Fair! Explore the service journeys of our wonderful juniors and seniors!</p>
  <!-- Add sorting options -->
  
  <div class="filter-section">
    <label for="service-category" style="font-weight: 600; color: #47763B;">Filter by:</label>
      <select name="service-category" id="service-category" onchange="window.location.href='/?category=' + this.value">
      <option value="cts" <%= currentCategory === 'cts' ? 'selected' : '' %>>Commitment to Service (CTS)</option>
      <option value="cap" <%= currentCategory === 'cap' ? 'selected' : '' %>>Community Action Project (CAP)</option>
      <hr>
        <option value="all" <%= !currentCategory || currentCategory === 'all' ? 'selected' : '' %>>All Projects</option>
        <option value="no-poverty" <%= currentCategory === 'no-poverty' ? 'selected' : '' %>>No Poverty</option>
        <option value="zero-hunger" <%= currentCategory === 'zero-hunger' ? 'selected' : '' %>>Zero Hunger</option>
        <option value="good-health" <%= currentCategory === 'good-health' ? 'selected' : '' %>>Good Health and Well-Being</option>
        <option value="quality-education" <%= currentCategory === 'quality-education' ? 'selected' : '' %>>Quality Education</option>
        <option value="gender-equality" <%= currentCategory === 'gender-equality' ? 'selected' : '' %>>Gender Equality</option>
        <option value="clean-water" <%= currentCategory === 'clean-water' ? 'selected' : '' %>>Clean Water and Sanitization</option>
        <option value="clean-energy" <%= currentCategory === 'clean-energy' ? 'selected' : '' %>>Affordable and Clean Energy</option>
        <option value="economic-growth" <%= currentCategory === 'economic-growth' ? 'selected' : '' %>>Decent Work and Economic Growth</option>
        <option value="innovation" <%= currentCategory === 'innovation' ? 'selected' : '' %>>Industry, Innovation, and Infrastructure</option>
        <option value="reduced-inequalities" <%= currentCategory === 'reduced-inequalities' ? 'selected' : '' %>>Reduced Inequalities</option>
        <option value="sustainable-cities" <%= currentCategory === 'sustainable-cities' ? 'selected' : '' %>>Sustainable Cities and Communities</option>
        <option value="responsible-consumption" <%= currentCategory === 'responsible-consumption' ? 'selected' : '' %>>Responsible Consumption and Production</option>
        <option value="climate-action" <%= currentCategory === 'climate-action' ? 'selected' : '' %>>Climate Action</option>
        <option value="life-below-water" <%= currentCategory === 'life-below-water' ? 'selected' : '' %>>Life Below Water</option>
        <option value="life-on-land" <%= currentCategory === 'life-on-land' ? 'selected' : '' %>>Life on Land</option>
        <option value="peace-justice" <%= currentCategory === 'peace-justice' ? 'selected' : '' %>>Peace, Justice, and Strong Institutions</option>
        <option value="partnerships" <%= currentCategory === 'partnerships' ? 'selected' : '' %>>Partnerships for the Goals</option>
      </select>
</div>
</header>

<!--Create a bunch of project cards-->
<main class="container">
    <div class="card-grid"> <% if (projects && projects.length > 0) { %>
      <% projects.forEach(project => { %>
        
        <div class="card">
          <img src="<%= project.image || 'https://via.placeholder.com/300x200?text=No+Image' %>" alt="Project Image">
          
          <h3><%= project.projectName %></h3>
          <p class="category-tag"><%= project.category %></p>
          
          <a href="/project/<%= project._id %>" class="view-btn">View Details</a>
        </div>

      <% }) %>
    <% } else { %>
      <p style="text-align: center; grid-column: 1/-1;">No projects found for this category.</p>
    <% } %>

  </div>
</main>

</body>
</html>